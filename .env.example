# Copy to .env and fill in. Used by docker-compose.yml.

# GitHub token so the `gh` CLI can read release metadata from github.com.
# A fine-grained or classic token with public read access is enough.
GH_TOKEN=

# Host port the UI is published on (container always listens on 8000).
PORT=8000

# Optional Basic Auth for the UI + management API. Set BOTH to enable a login.
# /payloads.json and /api/health always stay public (no auth).
# Leave empty to keep everything open.
MIRROR_AUTH_USER=
MIRROR_AUTH_PASSWORD=

# Optional "Publish to GitHub" button. Set ALL FOUR to enable it. The button
# commits payloads.json + README.md, runs `git pull --rebase`, then pushes.
# GIT_PASSWORD must be a GitHub Personal Access Token (PAT) with repo write
# access — GitHub no longer accepts account passwords over HTTPS.
GIT_USERNAME=
GIT_PASSWORD=
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
